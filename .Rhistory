# Load libraries
library(dplyr)
library(tidyverse)
# Pull Cleaned AI Data
crashes_and_cars = read.csv("clean_data/crash_data.csv")
# Filter to only AI data and identifiers
set.seed(123)
AI_Data = crashes_and_cars |>
select(make, model, car_year, drive_train, curb_weight, car_height, car_length, car_width)
AI_Validation_Sample = AI_Data |>
sample_frac(0.01)
write_csv(AI_Validation_Sample, "clean_data/AI_Validation_Sample_1pct.csv")
knitr::opts_chunk$set(echo = TRUE)
library(ggplot2)
library(haven)
library(dplyr)
crashes = read.csv("clean_data/crash_data.csv")
crashes |>
ggplot(aes(x = fatal)) +
geom_histogram() +
labs(
title = "Histogram of Crash fatality",
x = "Fatality of Car Crashes",
y = "Number of Crashes"
)
# Plot Driver and Passenger Safety Ratings by themselves
crashes |>
ggplot(aes(x = front_driver_stars)) +
geom_histogram() +
labs(
title = "Histogram of Driver Seat Safety Rating",
x = "Driver Seat Safety Rating Based on Crash Data",
y = "Number of Crashes"
)
# Plot Fatality by car safety rating for driver
crashes |>
group_by(front_driver_stars) |>
summarize(
mean_fatality = mean(fatal, na.rm = TRUE),
.groups = "drop"
) |>
ggplot(aes(x = front_driver_stars, y = mean_fatality)) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Safety Rating of the Driver Seat",
x = "Safety Rating of Vehicle for Driver",
y = "Average Fatality of Car Crashes"
)
crashes |>
group_by(front_driver_safetyrating) |>
summarize(
mean_fatality = mean(fatal, na.rm = TRUE),
.groups = "drop"
) |>
ggplot(aes(x = front_driver_safetyrating, y = mean_fatality)) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Safety Rating of the Driver Seat",
x = "Safety Rating of Vehicle for Driver",
y = "Average Fatality of Car Crashes"
)
crashes |>
group_by(front_passenger_safetyrating) |>
summarize(
mean_fatality = mean(fatal, na.rm = TRUE),
.groups = "drop"
) |>
ggplot(aes(x = front_passenger_safetyrating, y = mean_fatality)) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Safety Rating of the Passenger Seat",
x = "Safety Rating of Vehicle for Front Passenger",
y = "Average Fatality of Car Crashes"
)
crashes |>
ggplot(aes(x = curb_weight, y = mean_fatality)) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Weight of the Car",
x = "Weight of the Car (in kgs)",
y = "Average Fatality of Car Crashes"
)
crashes |>
ggplot(aes(x = curb_weight, y = fatal)) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Weight of the Car",
x = "Weight of the Car (in kgs)",
y = "Average Fatality of Car Crashes"
)
crashes |>
ggplot(aes(x = curb_weight, y = mean(fatal))) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Weight of the Car",
x = "Weight of the Car (in kgs)",
y = "Average Fatality of Car Crashes"
)
View(crashes)
crashes |>
ggplot(aes(x = curb_weight, y = mean(fatal)))
crashes |>
ggplot(aes(x = curb_weight, y = mean(fatal))) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Weight of the Car",
x = "Weight of the Car (in kgs)",
y = "Average Fatality of Car Crashes"
)
crashes |>
ggplot(aes(x = curb_weight, y = mean(fatal)))
crashes |>
ggplot(aes(x = curb_weight, y = mean(fatal))) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Weight of the Car",
x = "Weight of the Car (in kgs)",
y = "Average Fatality of Car Crashes"
)
crashes |>
ggplot(aes(x = curb_weight, y = mean(fatal, na.rm = TRUE))) +
geom_point() +
labs(
title = "Average Fatality in Crashes vs Weight of the Car",
x = "Weight of the Car (in kgs)",
y = "Average Fatality of Car Crashes"
)
crashes |>
filter(!is.na(curb_weight), !is.na(fatal)) |>
mutate(weight_bin = cut_width(curb_weight, width = 250)) |>
group_by(weight_bin) |>
summarize(
mean_fatality = mean(fatal),
mean_weight = mean(curb_weight),
.groups = "drop"
) |>
ggplot(aes(x = mean_weight, y = mean_fatality)) +
geom_point() +
