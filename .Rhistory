library(ISLR)
data(Credit)
set.seed(123)
credit_split = credit |> initial_split(prop = 0.8)
data(Credit)
force(Credit)
set.seed(123)
credit_split = credit |> initial_split(prop = 0.8)
View(Credit)
set.seed(123)
credit_split = Credit |> initial_split(prop = 0.8)
credit_train = credit_split |> training()
credit_test = credit_split |> testing()
credit_recipe = recipe(Rating ~ ., data = credit_train) |>
# Define ID variable so we don't use it as a predictor
update_role(ID, new_role = "id") |>
# Create indicators for each categorical or character variable
step_dummy(all_nominal_predictors())
# Process the data
credit_clean = credit_recipe |> prep() |> juice()
# Defining a  more complex recipe to process data
credit_recipe = recipe(Rating ~ ., data = credit_train) |>
# Define ID variable so we don't use it as a predictor
update_role(ID, new_role = "id") |>
# Create polynomial terms for numeric predictors
step_poly(all_numeric_predictors(), degree = 2) |>
# Create all possible interactions between continuous and categorical
step_interact(~all_numeric_predictors():all_nominal_predictors()) |>
# Create indicators for each categorical or character variable
step_dummy(all_nominal_predictors()) |>
# Remove predictors with ~0 variance
step_nzv(all_predictors())
# was 12 variables, then pre last line made 79, then last line made like 73ish
# Process the data so that you can look at it
credit_clean = credit_recipe |> prep() |> juice()
# Define a model
model_lm = linear_reg() |> set_engine("lm")
credit_cv = credit_train |> vfold_cv(v =5)
fit_lm_cv = workflow() |>
add_model(model_lm) |>
add_recipe(credit_recipe) |>
fit_resamples(credit_cv)
View(fit_lm_cv)
fit_lm_cv |> collect_metrics()
fit_lm_cv |> collect_metrics(summarize = F)
reg_model = linear_reg(penalty = tune(), mixture = 1) |>
set_engine("glmnet")
reg_workflow = workflow() |>
add_model(reg_model) |>
add_recipe(credit_recipe)
# Tune the lambda penalty parameter (estimate using cv for many values)
reg_cv = reg_workflow |>
tune_grid(credit_cv)
install.packages("glmnet")
