tm_shape(tracts_bonus) +
tm_polygons(
fill = "share_tract_with_access",
fill.scale = tm_scale_continuous(values = "Greens"),
fill.legend = tm_legend(title = "Share of tract within 1 km of park")
) +
tm_shape(nice_parks) +
tm_polygons(fill = "darkgreen", fill_alpha = 0.5) +
tm_title("Improved Park Access (Area Share by Census Tract)")
#--------------------------------------------------------
# Create comparison data
#--------------------------------------------------------
comparison <- tibble(
method = c("Tract-level (Q2)", "Improved (Area Share)"),
access_rate = c(0.6211687, 0.8368613)
)
#--------------------------------------------------------
# Plot
#--------------------------------------------------------
ggplot(comparison, aes(x = method, y = access_rate)) +
geom_col(fill = "#2E8B57") +
geom_text(
aes(label = scales::percent(access_rate, accuracy = 1)),
vjust = -0.5
) +
scale_y_continuous(labels = scales::percent_format(), limits = c(0,1)) +
labs(
title = "Improved Method Substantially Increases Estimated Park Access",
subtitle = "Comparison of tract-level vs. area-share approach",
x = "",
y = "Share of Population with Park Access"
) +
theme_minimal(base_size = 14)
