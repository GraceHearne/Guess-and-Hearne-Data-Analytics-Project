income_access <- ineq_data |>
group_by(income_quartile) |>
summarise(
population = sum(c_race, na.rm = TRUE),
pop_with_access = sum(c_race[has_park], na.rm = TRUE),
access_rate = pop_with_access / population
)
income_access |>
mutate(access_percent = access_rate * 100) |>
print()
#--------------------------------------------------------
# Graph
#--------------------------------------------------------
ggplot(income_access, aes(x = income_quartile, y = access_rate)) +
geom_col() +
scale_y_continuous(labels = scales::percent_format()) +
labs(
title = "Park Access by Income Group",
x = "Income Quartile",
y = "Share of Population with Park Access"
) +
theme_minimal()
#========================================================
# Improved population access using tract area shares!!!!
#========================================================
#--------------------------------------------------------
# Plan
#--------------------------------------------------------
# The tract-level method in Question 2 counts an entire tract as having
# park access if the tract intersects a nice park. That is a rough approximation.
#
# To improve this, I will:
# 1. Use the 1 km park access buffer from Question 1.
# 2. Intersect each Census tract with the park access buffer.
# 3. Calculate the share of each tract's area that is within 1 km of a nice park.
# 4. Assume population is evenly distributed within each tract.
# 5. Estimate the number of people with access as:
#       tract population × share of tract area with access
# 6. Divide by total population.
#--------------------------------------------------------
# Calculate total tract area
#--------------------------------------------------------
tracts_area <- tracts_alameda |>
mutate(
tract_area = as.numeric(st_area(geometry))
)
#--------------------------------------------------------
# Intersect tracts with the park access area
#--------------------------------------------------------
tract_access_area <- st_intersection(tracts_area, park_access_alameda) |>
mutate(
access_area = as.numeric(st_area(geometry))
) |>
st_drop_geometry() |>
group_by(GEOID) |>
summarise(
access_area = sum(access_area, na.rm = TRUE),
.groups = "drop"
)
#--------------------------------------------------------
# Join access area back to tracts
#--------------------------------------------------------
tracts_bonus <- tracts_area |>
left_join(tract_access_area, by = "GEOID") |>
mutate(
access_area = replace_na(access_area, 0),
share_tract_with_access = access_area / tract_area,
estimated_pop_with_access = c_race * share_tract_with_access
)
#--------------------------------------------------------
# Calculate improved population access estimate
#--------------------------------------------------------
bonus_summary <- tracts_bonus |>
st_drop_geometry() |>
summarise(
total_pop = sum(c_race, na.rm = TRUE),
estimated_pop_with_access = sum(estimated_pop_with_access, na.rm = TRUE),
estimated_fraction_with_access = estimated_pop_with_access / total_pop,
estimated_percent_with_access = estimated_fraction_with_access * 100
)
print(bonus_summary)
